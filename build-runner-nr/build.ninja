build cmake_object_order_depends_target_perf-io: phony || cmake_object_order_depends_target_core

build utils/CMakeFiles/perf-io.dir/perf/perf-io.cc.obj: CXX_COMPILER__perf-io_unscanned_RelWithDebInfo C$:/ns3-dev-link/utils/perf/perf-io.cc || cmake_object_order_depends_target_perf-io
  CONFIG = RelWithDebInfo
  DEFINES = -DHAVE_SQLITE3 -DNS3_BUILD_PROFILE_DEBUG -DPROJECT_SOURCE_PATH=\"C:/ns3-dev-link\" -DSTACKTRACE_LIBRARY_IS_LINKED=1 -D_USE_MATH_DEFINES
  DEP_FILE = utils\CMakeFiles\perf-io.dir\perf\perf-io.cc.obj.d
  FLAGS = -std=c++23   -fno-semantic-interposition -Wall -Wpedantic -Werror -Wno-error=deprecated-declarations
  INCLUDES = -IC:/ns3-dev-link/build/include
  OBJECT_DIR = utils\CMakeFiles\perf-io.dir
  OBJECT_FILE_DIR = utils\CMakeFiles\perf-io.dir\perf
  TARGET_COMPILE_PDB = utils\CMakeFiles\perf-io.dir\
  TARGET_PDB = C:\ns3-dev-link\build\utils\perf\ns3-dev-perf-io-relwithdebinfo.pdb
  TARGET_SUPPORT_DIR = utils\CMakeFiles\perf-io.dir


# =============================================================================
# Link build statements for EXECUTABLE target perf-io


#############################################
# Link the executable C:\ns3-dev-link\build\utils\perf\ns3-dev-perf-io-relwithdebinfo.exe

build C$:/ns3-dev-link/build/utils/perf/ns3-dev-perf-io-relwithdebinfo.exe: CXX_EXECUTABLE_LINKER__perf-io_RelWithDebInfo utils/CMakeFiles/perf-io.dir/perf/perf-io.cc.obj || C$:/ns3-dev-link/build/lib/libns3-dev-core-relwithdebinfo.dll
  CONFIG = RelWithDebInfo
  LINK_LIBRARIES = -Wl,--no-as-needed  C:/ns3-dev-link/build/lib/libns3-dev-core-relwithdebinfo.dll.a  -Wl,--as-needed  -Wl,--no-as-needed  -lwsock32  -lws2_32  -lstdc++exp  -lkernel32 -luser32 -lgdi32 -lwinspool -lshell32 -lole32 -loleaut32 -luuid -lcomdlg32 -ladvapi32
  LINK_PATH = -LC:/ns3-dev-link/build/lib
  OBJECT_DIR = utils\CMakeFiles\perf-io.dir
  POST_BUILD = cd .
  PRE_LINK = cd .
  TARGET_COMPILE_PDB = utils\CMakeFiles\perf-io.dir\
  TARGET_FILE = C:\ns3-dev-link\build\utils\perf\ns3-dev-perf-io-relwithdebinfo.exe
  TARGET_IMPLIB = C:\ns3-dev-link\build\lib\libperf-io.dll.a
  TARGET_PDB = C:\ns3-dev-link\build\utils\perf\ns3-dev-perf-io-relwithdebinfo.pdb
  TARGET_SUPPORT_DIR = utils\CMakeFiles\perf-io.dir


#############################################
# Utility command for edit_cache

build utils/CMakeFiles/edit_cache.util: CUSTOM_COMMAND
  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D C:\ns3-dev-link\build-runner-nr\utils && "C:\Program Files\CMake\bin\cmake-gui.exe" -SC:\ns3-dev-link -BC:\ns3-dev-link\build-runner-nr"
  DESC = Running CMake cache editor...
  pool = console
  restat = 1

build utils/edit_cache: phony utils/CMakeFiles/edit_cache.util


#############################################
# Utility command for rebuild_cache

build utils/CMakeFiles/rebuild_cache.util: CUSTOM_COMMAND
  COMMAND = C:\Windows\system32\cmd.exe /C "cd /D C:\ns3-dev-link\build-runner-nr\utils && C:\msys64\ucrt64\bin\cmake.exe --regenerate-during-build -SC:\ns3-dev-link -BC:\ns3-dev-link\build-runner-nr"
  DESC = Running CMake to regenerate build system...
  pool = console
  restat = 1

build utils/rebuild_cache: phony utils/CMakeFiles/rebuild_cache.util


